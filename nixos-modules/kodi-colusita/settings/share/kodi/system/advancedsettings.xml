<advancedsettings version="1.0">
    <!-- Enable remote control: https://kodi.wiki/view/Smartphone/tablet_remotes#Manually_enabling_remote_control -->
    <services>
        <devicename>@devicename@</devicename>
        <esenabled>true</esenabled>
        <esallinterfaces>true</esallinterfaces>
        <webserver>true</webserver>
        <webserverauthentication>false</webserverauthentication>
        <zeroconf>true</zeroconf>
    </services>
    <audiooutput>
        <!-- https://github.com/xbmc/xbmc/blob/21.3-Omega/system/settings/settings.xml#L3222-L3224 -->
        <guisoundmode>2</guisoundmode> <!-- AE_SOUND_ALWAYS -->
    </audiooutput>
</advancedsettings>
