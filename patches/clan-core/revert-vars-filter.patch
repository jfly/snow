+            ++ lib.optionals (_class == "darwin") (v.darwinImports or [ ]);
+
+            # default hostname
+            networking.hostName = lib.mkDefault name;
+          }
+        )
+      ) config.clanInternals.inventoryClass.machines)
+
+      # The user can define some machine config here
+      # i.e. 'clan.machines.jon = ...'
